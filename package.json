{
  "name": "eurolab-pro",
  "version": "0.1.0",
  "private": true,
  "description": "Professional desktop Laboratory Information Management System.",
  "author": "Eurolab Pro",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --config vite.config.ts\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run typecheck && vite build --config vite.config.ts && tsc -p tsconfig.electron.json",
    "preview": "vite preview --config vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "clsx": "^2.1.1",
    "electron": "^33.2.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
